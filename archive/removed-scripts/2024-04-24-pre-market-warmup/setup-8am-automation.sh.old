#!/bin/bash
# Setup script for Staged Pre-Market Automation
# Installs cron jobs for phased 17-tier verification + warmup
#
# Timeline:
#   06:00 AM ET - Early Infrastructure (Tiers 1-5)
#   07:00 AM ET - Data Pipeline (Tiers 6-10)
#   07:50 AM ET - Pre-Market Validation (Tiers 11-17)
#   08:00 AM ET - Warmup starts
#   09:30 AM ET - Market Open Transition
#
# Usage: ./scripts/ops/setup-8am-automation.sh [--target-mode MODE] [--manual]

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e "${GREEN}✅${NC} $1"; }
warn() { echo -e "${YELLOW}⚠️${NC} $1"; }
fail() { echo -e "${RED}❌${NC} $1"; }
info() { echo -e "${BLUE}ℹ️${NC} $1"; }
header() { echo -e "${BOLD}${CYAN}═══ $1 ═══${NC}"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPXER_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"
cd "$SPXER_DIR"

# Parse arguments
TARGET_MODE="SIMULATION"
MANUAL_MODE=false
for arg in "$@"; do
    case $arg in
        --target-mode)
            TARGET_MODE="$2"
            shift 2
            ;;
        --manual)
            MANUAL_MODE=true
            shift
            ;;
    esac
done

echo -e "${BOLD}${CYAN}"
echo "╔════════════════════════════════════════╗"
echo "║   SPXer Staged Pre-Market Automation  ║"
echo "║   Phased 17-Tier Verification          ║"
echo "╚════════════════════════════════════════╝"
echo -e "${NC}"
echo
echo "Target mode: $TARGET_MODE"
echo "Manual mode: $MANUAL_MODE"
echo

# Show timeline
header "Daily Timeline"
cat << 'EOF'
06:00 AM ET ── Early Infrastructure Checks (Tiers 1-5)
             ── Tool functionality, readings, calculations, signal logic, config

07:00 AM ET ── Data Pipeline Checks (Tiers 6-10)
             ── System visibility, E2E pipeline, state, freshness, acceptance

07:50 AM ET ── Pre-Market Validation (Tiers 11-17)
             ── Market state, financial, time decay, network, data quality, human, regulatory

08:00 AM ET ── Warmup Phase 1 Starts
             ── All checks passed, signal tracking begins (backfilled data)

09:30 AM ET ── Market Open (still in WARMUP)

09:42 AM ET ── First Valid HMA(12) appears
             ── First possible HMA(3)×HMA(12) cross on TODAY'S data

09:42-10:00 AM ET ── Warmup Phase 2 (REAL signals on today's data)

10:00 AM ET ── Transition to SIMULATION/LIVE
             ── Actual trading begins (on validated signals)
EOF
echo

# ============================================================================
# STEP 1: Verify Prerequisites
# ============================================================================
header "Step 1: Verifying Prerequisites"
echo

# Check crontab
if ! command -v crontab &> /dev/null; then
    fail "crontab not found - install cron first"
    exit 1
fi
pass "crontab available"

# Check scripts
SCRIPTS=(
    "$SCRIPT_DIR/check-early-infrastructure.sh"
    "$SCRIPT_DIR/check-data-pipeline.sh"
    "$SCRIPT_DIR/check-pre-market-validation.sh"
    "$SCRIPT_DIR/start-warmup-with-checklist.sh"
    "$SCRIPT_DIR/transition-from-warmup.sh"
)

for script in "${SCRIPTS[@]}"; do
    if [ ! -f "$script" ]; then
        fail "Script not found: $script"
        exit 1
    fi
    chmod +x "$script"
done
pass "All scripts found and marked executable"

# Create logs directory
LOG_DIR="$SPXER_DIR/logs"
mkdir -p "$LOG_DIR"
pass "Logs directory ready: $LOG_DIR"

echo

# ============================================================================
# STEP 2: Create Cron Entries
# ============================================================================
header "Step 2: Creating Cron Entries"
echo

# Backup existing crontab
CRON_BACKUP="$HOME/spxer-crontab-backup-$(date +%Y%m%d-%H%M%S)"
crontab -l > "$CRON_BACKUP" 2>/dev/null || touch "$CRON_BACKUP"
pass "Existing crontab backed up to: $CRON_BACKUP"

# Create new crontab
NEW_CRON="$HOME/spxer-cron-new"
cp "$CRON_BACKUP" "$NEW_CRON"

# Add comment header
{
    echo ""
    echo "# ============================================================================ "
    echo "# SPXer Staged Pre-Market Automation - Added $(date)"
    echo "# ============================================================================ "
} >> "$NEW_CRON"

# Add staged cron entries
if [ "$MANUAL_MODE" = false ]; then
    # Always add the first 3 checks (time-independent)
    cat >> "$NEW_CRON" << EOF

# 06:00 AM ET - Early Infrastructure (Tiers 1-5)
0 6 * * 1-5 cd $SPXER_DIR && ./scripts/ops/check-early-infrastructure.sh >> logs/cron-0600-\$(date +\\%Y\\%m\\%d).log 2>&1

# 07:00 AM ET - Data Pipeline (Tiers 6-10)
0 7 * * 1-5 cd $SPXER_DIR && ./scripts/ops/check-data-pipeline.sh >> logs/cron-0700-\$(date +\\%Y\\%m\\%d).log 2>&1

# 07:50 AM ET - Pre-Market Validation (Tiers 11-17)
50 7 * * 1-5 cd $SPXER_DIR && ./scripts/ops/check-pre-market-validation.sh >> logs/cron-0750-\$(date +\\%Y\\%m\\%d).log 2>&1

# 08:00 AM ET - Warmup Phase 1 Starts
0 8 * * 1-5 export WARMUP_TARGET_MODE=$TARGET_MODE && cd $SPXER_DIR && ./scripts/ops/start-warmup-with-checklist.sh >> logs/cron-0800-\$(date +\\%Y\\%m\\%d).log 2>&1
EOF

    # Calculate transition time from config if available
    if [ -n "${AGENT_CONFIG_ID:-}" ]; then
        echo
        info "Calculating transition time from config: $AGENT_CONFIG_ID"

        # Run calculator and parse output
        CALC_OUTPUT=$($SCRIPT_DIR/calculate-transition-from-config.sh 2>&1)

        # Extract the cron line from calculator output
        TRANSITION_CRON=$(echo "$CALC_OUTPUT" | grep "0 [0-9][0-9] \* \* 1-5.*transition-from-warmup" | tail -1 || "")

        if [ -n "$TRANSITION_CRON" ]; then
            echo "$TRANSITION_CRON" >> "$NEW_CRON"
            pass "Transition cron calculated from config"
        else
            warn "Could not calculate transition time from config, using default 10:15 AM"
            echo "# 10:15 AM ET - Transition (default - update based on your config!)" >> "$NEW_CRON"
            echo "15 10 * * 1-5 export WARMUP_TARGET_MODE=$TARGET_MODE && cd $SPXER_DIR && ./scripts/ops/transition-from-warmup.sh >> logs/cron-1015-\$(date +\\%Y\\%m\\%d).log 2>&1" >> "$NEW_CRON"
            warn "Run: ./scripts/ops/calculate-transition-from-config.sh"
            warn "Then edit crontab with the calculated time"
        fi
    else
        # No config ID - use default with warning
        echo "# 10:15 AM ET - Transition (DEFAULT - set AGENT_CONFIG_ID for accuracy!)" >> "$NEW_CRON"
        echo "15 10 * * 1-5 export WARMUP_TARGET_MODE=$TARGET_MODE && cd $SPXER_DIR && ./scripts/ops/transition-from-warmup.sh >> logs/cron-1015-\$(date +\\%Y\\%m\\%d).log 2>&1" >> "$NEW_CRON"
        warn "AGENT_CONFIG_ID not set - using default 10:15 AM transition"
        warn "Set AGENT_CONFIG_ID and re-run for accurate timing"
    fi

    pass "Cron entries added (automatic mode)"
else
    # Manual mode - just reminders, no actual transition time hard-coded
    cat >> "$NEW_CRON" << EOF

# 06:00 AM ET - Manual reminder
0 6 * * 1-5 echo "⏰ 06:00 - Early infrastructure checks: cd $SPXER_DIR && ./scripts/ops/check-early-infrastructure.sh" | logger -t spxer-reminder

# 07:00 AM ET - Manual reminder
0 7 * * 1-5 echo "⏰ 07:00 - Data pipeline checks: cd $SPXER_DIR && ./scripts/ops/check-data-pipeline.sh" | logger -t spxer-reminder

# 07:50 AM ET - Manual reminder
50 7 * * 1-5 echo "⏰ 07:50 - Pre-market validation: cd $SPXER_DIR && ./scripts/ops/check-pre-market-validation.sh" | logger -t spxer-reminder

# 08:00 AM ET - Manual reminder
0 8 * * 1-5 echo "⏰ 08:00 - Start warmup: cd $SPXER_DIR && ./scripts/ops/start-warmup-with-checklist.sh" | logger -t spxer-reminder
EOF
    pass "Cron entries added (manual reminder mode)"
fi

echo

# ============================================================================
# STEP 3: Install Crontab
# ============================================================================
header "Step 3: Installing Crontab"
echo

echo "Cron schedule to be installed:"
echo "─────────────────────────────────"
echo "06:00 AM ET (Mon-Fri): Early Infrastructure (Tiers 1-5)"
echo "07:00 AM ET (Mon-Fri): Data Pipeline (Tiers 6-10)"
echo "07:50 AM ET (Mon-Fri): Pre-Market Validation (Tiers 11-17)"
echo "08:00 AM ET (Mon-Fri): Warmup Phase 1 starts"
echo "10:06 AM ET: First valid HMA(12) on 3m timeframe (12 bars × 3min)"
echo "10:15 AM ET (Mon-Fri): Transition to $TARGET_MODE mode (NOT 09:30!)"
echo "─────────────────────────────────"
echo
echo "Why 10:15 AM and not 09:30 AM?"
echo "  • Your config: HMA(3)×HMA(12) on 3m timeframe"
echo "  • HMA(12) needs: 12 bars × 3 minutes = 36 minutes"
echo "  • Market opens: 09:30 AM ET"
echo "  • First HMA(12) valid: 09:30 + 36 = 10:06 AM ET"
echo "  • 10:15 AM gives 9-min buffer to verify signal quality"
echo
echo "For 1m timeframe configs, use 10:00 AM ET instead"
echo "  Run: ./scripts/ops/calculate-warmup-end.sh 12 1 15"
echo

read -p "Install these cron jobs? (y/N): " CONFIRM
if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "Aborted"
    rm -f "$NEW_CRON"
    exit 0
fi

crontab "$NEW_CRON"
pass "Crontab installed"
rm -f "$NEW_CRON"

echo

# ============================================================================
# STEP 4: Verify Installation
# ============================================================================
header "Step 4: Verifying Installation"
echo

echo "Current crontab (SPXer entries):"
echo "─────────────────────────────────"
crontab -l | grep -A 20 "SPXer Staged Pre-Market Automation" || echo "No SPXer entries found"
echo "─────────────────────────────────"
echo

# Check cron service
if systemctl is-active --quiet cron 2>/dev/null || systemctl is-active --quiet crond 2>/dev/null; then
    pass "Cron service is running"
else
    warn "Cron service may not be running"
fi

echo

# ============================================================================
# STEP 5: Next Steps
# ============================================================================
header "Setup Complete"
echo

echo -e "${GREEN}${BOLD}✅ Staged automation installed successfully!${NC}"
echo
echo "Daily Schedule:"
echo "  🕐 06:00 AM ET: Early Infrastructure (Tiers 1-5)"
echo "  🕐 07:00 AM ET: Data Pipeline (Tiers 6-10)"
echo "  🕐 07:50 AM ET: Pre-Market Validation (Tiers 11-17)"
echo "  🕐 08:00 AM ET: Warmup Phase 1 starts (backfilled data)"
echo "  🕐 10:06 AM ET: First valid HMA(12) on 3m timeframe"
echo "  🕐 10:15 AM ET: Transition to $TARGET_MODE mode"
echo
echo "Monitor logs:"
echo "  tail -f logs/cron-0600-\$(date +%Y%m%d).log  # 06:00 checks"
echo "  tail -f logs/cron-0700-\$(date +%Y%m%d).log  # 07:00 checks"
echo "  tail -f logs/cron-0750-\$(date +%Y%m%d).log  # 07:50 checks"
echo "  tail -f logs/cron-0800-\$(date +%Y%m%d).log  # 08:00 warmup"
echo "  tail -f logs/cron-1015-\$(date +%Y%m%d).log  # 10:15 transition"
echo
echo "Test manually:"
echo "  ./scripts/ops/check-early-infrastructure.sh"
echo "  ./scripts/ops/check-data-pipeline.sh"
echo "  ./scripts/ops/check-pre-market-validation.sh"
echo "  ./scripts/ops/start-warmup-with-checklist.sh"
echo
echo "Remove automation:"
echo "  crontab -e  # Delete SPXer entries"
echo "  crontab $CRON_BACKUP  # Restore old crontab"
echo
echo "Cron backup: $CRON_BACKUP"
echo

exit 0

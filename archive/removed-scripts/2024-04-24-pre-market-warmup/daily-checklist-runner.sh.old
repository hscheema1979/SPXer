#!/bin/bash
# Master Daily Checklist Runner
# Executes all sections in sequence with timestamps

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e "${GREEN}✅${NC} $1"; }
warn() { echo -e "${YELLOW}⚠️${NC} $1"; }
fail() { echo -e "${RED}❌${NC} $1"; }
section() { echo -e "${BOLD}${BLUE}═══ $1 ═══${NC}"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPXER_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"

cd "$SPXER_DIR" || {
    fail "Cannot cd to SPXER directory: $SPXER_DIR"
    exit 1
}

TOTAL_PASS=0
TOTAL_FAIL=0

echo -e "${BOLD}${BLUE}"
echo "╔════════════════════════════════════════╗"
echo "║   SPXer Daily Operations Checklist    ║"
echo "║   Surgical Precision for Trading     ║"
echo "╚════════════════════════════════════════╝"
echo -e "${NC}"
echo
echo "Started: $(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "User: $(whoami)@$(hostname)"
echo

# Parse command line arguments
SECTION=${1:-"all"}
SKIP_TO=${2:-""}

if [ "$SECTION" = "help" ] || [ "$SECTION" = "-h" ] || [ "$SECTION" = "--help" ]; then
    echo "Usage: $0 [section] [skip_to]"
    echo
    echo "Sections:"
    echo "  all       - Run full daily checklist (default)"
    echo "  pre       - Section A: Pre-Market Setup (06:00-08:00)"
    echo "  open      - Section B: Market Open Prep (09:00-09:30)"
    echo "  monitor   - Section C: Market Hours Monitor (10:00-16:00)"
    echo "  close     - Section D: Post-Market Close (16:00-16:30)"
    echo "  eod       - Section E: End of Day (16:30-17:00)"
    echo "  quick     - Quick health check only"
    echo
    echo "Examples:"
    echo "  $0 all                    # Full checklist"
    echo "  $0 pre                    # Pre-market checks only"
    echo "  $0 monitor                # Active trading monitor"
    echo "  $0 all B3                 # Skip to section B3"
    echo
    exit 0
fi

# Function to run a check script
run_check() {
    local check_name=$1
    local check_script=$2
    local required=${3:-true}

    section "$check_name"

    if [ ! -f "$check_script" ]; then
        if [ "$required" = "true" ]; then
            fail "Script not found: $check_script"
            TOTAL_FAIL=$((TOTAL_FAIL + 1))
            return 1
        else
            warn "Script not found: $check_script (optional)"
            return 0
        fi
    fi

    if [ ! -x "$check_script" ]; then
        warn "Making executable: $check_script"
        chmod +x "$check_script"
    fi

    if bash "$check_script"; then
        pass "$check_name: PASSED"
        TOTAL_PASS=$((TOTAL_PASS + 1))
        return 0
    else
        fail "$check_name: FAILED"
        TOTAL_FAIL=$((TOTAL_FAIL + 1))

        # Ask if we should continue
        if [ "$required" = "true" ]; then
            echo
            read -p "Continue to next section? (y/N): " CONTINUE
            if [ "$CONTINUE" != "y" ] && [ "$CONTINUE" != "Y" ]; then
                echo "Aborted by user"
                exit 1
            fi
        fi
        return 1
    fi
}

# ============================================================================
# SECTION A: PRE-MARKET SETUP (06:00-08:00)
# ============================================================================
if [ "$SECTION" = "all" ] || [ "$SECTION" = "pre" ]; then
    if [ -z "$SKIP_TO" ] || [[ "$SKIP_TO" < "A" ]]; then
        echo
        section "SECTION A: PRE-MARKET SETUP (06:00-08:00)"
        echo

        run_check "A1: Environment" "$SCRIPT_DIR/check-environment.sh" true
        run_check "A2: Databases" "$SCRIPT_DIR/check-databases.sh" true
        run_check "A3: Providers" "$SCRIPT_DIR/check-providers.sh" true
        run_check "A4: Configs" "$SCRIPT_DIR/validate-configs.sh" true
        run_check "A5: Reconciliation" "$SCRIPT_DIR/reconcile-positions.sh" true
        run_check "A6: Alerts" "$SCRIPT_DIR/test-alerts.sh" false
    fi
fi

# ============================================================================
# SECTION B: MARKET OPEN PREPARATION (09:00-09:30)
# ============================================================================
if [ "$SECTION" = "all" ] || [ "$SECTION" = "open" ]; then
    if [ -z "$SKIP_TO" ] || [[ "$SKIP_TO" < "B" ]]; then
        echo
        section "SECTION B: MARKET OPEN PREPARATION (09:00-09:30)"
        echo

        run_check "B1: Handler Startup" "$SCRIPT_DIR/start-handler.sh" true
        run_check "B2: Data Quality" "$SCRIPT_DIR/check-data-quality.sh" true
        run_check "B3: Signal Pipeline" "$SCRIPT_DIR/test-signal-pipeline.sh" true
        run_check "B4: Final GO" "$SCRIPT_DIR/final-go-check.sh" true
    fi
fi

# ============================================================================
# SECTION C: MARKET HOURS (09:30-16:00)
# ============================================================================
if [ "$SECTION" = "all" ] || [ "$SECTION" = "monitor" ]; then
    if [ -z "$SKIP_TO" ] || [[ "$SKIP_TO" < "C" ]]; then
        echo
        section "SECTION C: MARKET HOURS MONITOR (09:30-16:00)"
        echo

        run_check "C1: First 30 Min" "$SCRIPT_DIR/monitor-first-30.sh" false
        run_check "C2: Ongoing Monitor" "$SCRIPT_DIR/monitor-active-trading.sh" true
    fi
fi

# ============================================================================
# SECTION D: POST-MARKET CLOSE (16:00-16:30)
# ============================================================================
if [ "$SECTION" = "all" ] || [ "$SECTION" = "close" ]; then
    if [ -z "$SKIP_TO" ] || [[ "$SKIP_TO" < "D" ]]; then
        echo
        section "SECTION D: POST-MARKET CLOSE (16:00-16:30)"
        echo

        run_check "D1: Reconciliation" "$SCRIPT_DIR/post-market-reconcile.sh" true
        run_check "D2: Archival" "$SCRIPT_DIR/archive-day.sh" true
        run_check "D3: Daily Report" "$SCRIPT_DIR/daily-report.sh" false
        run_check "D4: Shutdown" "$SCRIPT_DIR/shutdown-handler.sh" true
    fi
fi

# ============================================================================
# SECTION E: END OF DAY (16:30-17:00)
# ============================================================================
if [ "$SECTION" = "all" ] || [ "$SECTION" = "eod" ]; then
    if [ -z "$SKIP_TO" ] || [[ "$SKIP_TO" < "E" ]]; then
        echo
        section "SECTION E: END OF DAY (16:30-17:00)"
        echo

        run_check "E1: Tomorrow's Prep" "$SCRIPT_DIR/prepare-tomorrow.sh" true
        run_check "E2: Daily Sign-Off" "$SCRIPT_DIR/daily-signoff.sh" false
    fi
fi

# ============================================================================
# QUICK HEALTH CHECK
# ============================================================================
if [ "$SECTION" = "quick" ]; then
    echo
    section "QUICK HEALTH CHECK"
    echo

    run_check "Environment" "$SCRIPT_DIR/check-environment.sh" true
    run_check "Providers" "$SCRIPT_DIR/check-providers.sh" true

    if pm2 describe event-handler &> /dev/null; then
        run_check "Active Monitor" "$SCRIPT_DIR/monitor-active-trading.sh" false
    fi
fi

# ============================================================================
# SUMMARY
# ============================================================================
echo
section "DAILY CHECKLIST COMPLETE"
echo
echo "Started:  $(date '+%Y-%m-%d %H:%M:%S %Z' -d "$START_TIME" 2>/dev/null || echo "N/A")"
echo "Finished: $(date '+%Y-%m-%d %H:%M:%S %Z')"
echo
echo -e "${BOLD}Results:${NC}"
echo "  ✅ Passed: $TOTAL_PASS"
echo "  ❌ Failed: $TOTAL_FAIL"
echo

if [ $TOTAL_FAIL -eq 0 ]; then
    echo -e "${GREEN}${BOLD}ALL CHECKS PASSED - READY FOR TRADING${NC}"
    exit 0
else
    echo -e "${RED}${BOLD}SOME CHECKS FAILED - REVIEW REQUIRED${NC}"
    exit 1
fi

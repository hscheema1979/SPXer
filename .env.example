PORT=3600
TRADIER_TOKEN=your_tradier_token
TRADIER_ACCOUNT_ID=your_account_id
GDRIVE_REMOTE=gdrive:SPXer/archives
DB_PATH=./data/spxer.db
LOG_LEVEL=info

# Autonomous Trading Agent — Multi-Model Consensus
ANTHROPIC_API_KEY=your_anthropic_api_key   # for Opus judge (Tier 2)
SPXER_URL=http://localhost:3600

# LiteLLM proxy (Tier 1 scanners: Kimi, GLM-5, MiniMax via Chutes)
LITELLM_BASE_URL=http://localhost:4010/v1
LITELLM_KEY=sk-litellm-master-simplepilot

# Scanner models (override if needed)
# KIMI_MODEL=moonshotai-kimi-k2.5-tee
# GLM_MODEL=zai-org-glm-5-tee
# MINIMAX_MODEL=minimaxai-minimax-m2.5-tee

# Judge model (override if needed)
# OPUS_MODEL=claude-opus-4-6

AGENT_PAPER=true
AGENT_MAX_DAILY_LOSS=2000
AGENT_MAX_POSITIONS=2
AGENT_MAX_RISK_PER_TRADE=500
AGENT_CUTOFF_ET=15:30
AGENT_MIN_MINS_TO_CLOSE=60
